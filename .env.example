# =====================================================================
# SAMBA EXPORT CONTROL DESK - ENV CONFIG
# =====================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA commite o `.env` (ja esta no .gitignore).

# ---------------------------------------------------------------------
# LLM / Modelos
# ---------------------------------------------------------------------
# Google Gemini API (gratuito - 15 req/min)
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-chave-aqui

# Claude API (Anthropic) - mantido como fallback opcional
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---------------------------------------------------------------------
# Google Drive / Sheets
# ---------------------------------------------------------------------
GOOGLE_DRIVE_FOLDER_ID=0AOllQoxhuNj4Uk9PVA
GOOGLE_CREDENTIALS_FILE=config/google_credentials.json

# ---------------------------------------------------------------------
# SAMBA CORE ENGINE - Celery + Redis
# ---------------------------------------------------------------------
# Broker e backend de resultados do Celery.
# DEV (Windows + WSL):  redis://localhost:6379/0
# DEV (Memurai nativo): redis://localhost:6379/0
# DOCKER COMPOSE:       redis://redis:6379/0  (servico interno)
# PROD (Railway/Render): use a connection string fornecida pelo provedor
REDIS_URL=redis://localhost:6379/0

# Periodo (em minutos) do Beat para sincronizar Sheets -> Drive.
SAMBA_BEAT_SYNC_MINUTES=10

# ---------------------------------------------------------------------
# SAMBA CORE ENGINE - FastAPI Webhook
# ---------------------------------------------------------------------
# Validacao de assinatura HMAC-SHA1 da Twilio.
#
# DEV:  false  (permite curl/Postman direto - ideal para smoke test)
# PROD: true   (OBRIGATORIO - protege contra POSTs forjados)
TWILIO_VALIDATE_SIGNATURE=false

# URL publica que a Twilio chama (necessaria em PROD para a SDK
# reconstruir a string assinada). Em DEV pode ficar vazia.
# Exemplo PROD: https://samba-core.up.railway.app/webhook/twilio
TWILIO_WEBHOOK_PUBLIC_URL=

# ---------------------------------------------------------------------
# Twilio (WhatsApp Business API)
# ---------------------------------------------------------------------
# Credenciais globais (fallback)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx

# Chips dedicados por agente (numeros E.164)
AGENT_EXTRACTOR_PHONE=+5513999990001
AGENT_FOLLOWUP_PHONE=+5513999990002
AGENT_MANAGER_PHONE=+5513999990003
AGENT_DOCUMENTAL_PHONE=+5513999990004
AGENT_AGENDA_PHONE=+5513999990005

# Credenciais Twilio por agente (opcional - usa global acima se omitido)
# AGENT_EXTRACTOR_TWILIO_SID=ACxxxxx
# AGENT_EXTRACTOR_TWILIO_TOKEN=xxxxx
# AGENT_FOLLOWUP_TWILIO_SID=ACxxxxx
# AGENT_FOLLOWUP_TWILIO_TOKEN=xxxxx
# AGENT_MANAGER_TWILIO_SID=ACxxxxx
# AGENT_MANAGER_TWILIO_TOKEN=xxxxx
# AGENT_DOCUMENTAL_TWILIO_SID=ACxxxxx
# AGENT_DOCUMENTAL_TWILIO_TOKEN=xxxxx
# AGENT_AGENDA_TWILIO_SID=ACxxxxx
# AGENT_AGENDA_TWILIO_TOKEN=xxxxx

# Modo offline - simula envios no terminal sem chamar a API (dev)
WHATSAPP_OFFLINE=true

# ---------------------------------------------------------------------
# Socios
# ---------------------------------------------------------------------
SOCIO_1_NAME=Leonardo
SOCIO_1_PHONE=+5513996259995
SOCIO_2_NAME=Nivio
SOCIO_2_PHONE=+55xxxxx
SOCIO_3_NAME=Marcelo
SOCIO_3_PHONE=+55xxxxx

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------
DATABASE_URL=sqlite:///data/samba_control.db

# ---------------------------------------------------------------------
# ESALQ Scraper
# ---------------------------------------------------------------------
ESALQ_SCRAPE_HOUR=07:00

# ---------------------------------------------------------------------
# Geopolitical Sentinel — NewsData.io (Sprint M)
# ---------------------------------------------------------------------
# Free tier: 200 req/dia por chave. Com 2 chaves = 400 req/dia.
# Budget real com schedule 30min: 48 runs x 5 buckets = 240 req/dia — OK.
# Registrar em: https://newsdata.io/register
NEWSDATA_KEY_1=pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEWSDATA_KEY_2=pub_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Fallback legado NewsAPI.org (omitir se usar NewsData.io)
# NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# Voice ATA — Gemini 1.5 Pro multimodal (Sprint M)
# ---------------------------------------------------------------------
# Modelo usado para transcrição de áudios WhatsApp e geração de ATA.
# Default: gemini-1.5-pro (não requer configuração explícita)
# VOICE_ATA_MODEL=gemini-1.5-pro
